<!-- Header for small screens-->

<!-- Menu icon -->
<div onclick="openMenu()" class="flex gap-2 lg:block bg-primary-dark">
  <button class="lg:hidden "><svg xmlns="http://www.w3.org/2000/svg" height="34px" viewBox="0 -960 960 960" width="34px" fill="white">
      <path d="M120-240v-80h720v80H120Zm0-200v-80h720v80H120Zm0-200v-80h720v80H120Z" />
    </svg></button>
  <h1 class="  text-white  text-4xl p-1">Tech Inventory</h1>
</div>

<!-- drawer -->
<div id="drawer" class=" fixed top-0 left-0 h-full w-64 bg-primary-dark shadow-2xl z-50 transform -translate-x-full transition-transform duration-300 ease-in-out">
  <div onclick="closeMenu()" class="text-xl font-bold text-end text-white pr-2">x</div>
  <!-- menu heading -->
  <div class="flex justify-between px-2">
    <p class="text-xl text-white">Categories </p>
  </div>

  <ul class="text-white p-1 ">
    <% categories.forEach(category=>{ %>
    <li class=" list-item p-1" onclick="showItemsFromServer('<%= `/category/${category.id}` %>','items-div')"><%= category.name%></li>
    <hr>
    <% }) %>
  </ul>
</div>


<!-- Category header for large screens -->
<div class=" hidden mt-2 ml-1 lg:flex flex-wrap gap-2">
  <button onclick="showAddCategoryForm()" class=" text-xl font-bold pl-2 pr-2 pt-1 pb-1 border  border-primary rounded-md hover:bg-primary-dark hover:text-white cursor-pointer">+</button>

  <!-- Edit Button for large screens -->
  <%- include('../partials/editFormLargeScreen')%>
  <%- include('../partials/editFormSmallScreen')%>

  <% categories.forEach(category=>{ %>
  <button class=" p-2 border border-primary rounded-md 
  hover:bg-primary-dark hover:text-white hover:border-transparent cursor-pointer" onclick="showItemsFromServer('<%= `/category/${category.id}` %>','items-div')"><%= category.name%></button>
  <% }) %>
</div>

<!-- Items Table -->
<div id="items-div">

</div>


<!-- Edit Button For Small Screens only at bottom right-->
<div onclick="editButtonForSmallScreen()" id="sm:editButton" class="lg:hidden fixed top-11/12 left-10/12  p-2 bg-primary-dark border-none rounded-lg"><svg xmlns="http://www.w3.org/2000/svg" height="35px" viewBox="0 -960 960 960" width="35px" fill="#e3e3e3">
    <path d="M216-216h51l375-375-51-51-375 375v51Zm-72 72v-153l498-498q11-11 23.84-16 12.83-5 27-5 14.16 0 27.16 5t24 16l51 51q11 11 16 24t5 26.54q0 14.45-5.02 27.54T795-642L297-144H144Zm600-549-51-51 51 51Zm-127.95 76.95L591-642l51 51-25.95-25.05Z" />
  </svg></div>