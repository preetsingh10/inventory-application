<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventory Application</title>
  <link rel="stylesheet" href="/output.css">
  <script src="/index.js"></script>
</head>

<body>
  <h1 class="text-pink-500 text-3xl ">Tech Inventory</h1>

  <div  class="mt-2 ml-1 flex flex-wrap gap-1">
    <button onclick="showAddCategoryForm()" class=" text-xl font-bold pl-2 pr-2 pt-1 pb-1 border  border-pink-400 rounded-md hover:bg-pink-600 hover:text-white cursor-pointer">+</button>
    <dialog id="add-category" class="m-auto rounded-2xl shadow-2xl border border-pink-200 p-0 w-full max-w-md backdrop:bg-black/40">
      <div class="bg-white rounded-2xl overflow-hidden">

        <!-- Header -->
        <div class="bg-pink-500 px-6 py-4 flex items-center justify-between">
          <h2 class="text-white font-semibold text-lg tracking-wide">Add Category</h2>
          <button onclick="removeAddCategoryForm()" class="text-white hover:text-pink-200 text-xl font-bold cursor-pointer">✕</button>
        </div>

        <!-- Form -->
        <form action="add-category1" class="px-6 py-6 flex flex-col gap-4">

          <div class="flex flex-col gap-1">
            <label for="categoryName" class="text-sm font-medium text-gray-600">Name</label>
            <input type="text" name="category-name" id="categoryName" placeholder="e.g. Electronics" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition" />
          </div>

          <!-- Buttons -->
          <div class="flex justify-end gap-2 pt-2">
            <button type="button" onclick="removeAddCategoryForm()" class="px-4 py-2 text-sm rounded-lg border border-pink-300 text-pink-500 hover:bg-pink-50 transition cursor-pointer">
              Cancel
            </button>
            <button type="submit" class="px-4 py-2 text-sm rounded-md bg-pink-500 text-white hover:bg-pink-600 transition cursor-pointer">
              Add Category
            </button>
          </div>
        </form>
      </div>
    </dialog>
    <% categories.forEach(category=>{ %>
    <a class="  
    border border-pink-400 rounded-md px-1 py-1.5
  hover:bg-pink-600 hover:text-white " href=<%=`/category/${category.id}`%>><%= category.name%></a>
    <% }) %>
  </div>

</body>

</html>