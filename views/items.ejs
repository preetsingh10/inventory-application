<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/output.css">
  <title>Items</title>
</head>

<body>
  <h2>Items</h2>
<% if (items.length === 0) { %>
  <h1>No items in this category</h1>
<% } else { %>
  <% items.forEach(item => { %>
    <p>
      Name: <%= item.name %>
      Price: $<%= item.price %>
      Quantity: <%= item.quantity %> pcs
    </p>
  <% }) %>
<% } %>
</body>

</html>