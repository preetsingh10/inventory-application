<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventory Application</title>
  <link rel="stylesheet" href="/output.css">
</head>

<body>
  <h1 class="text-pink-500 text-3xl ">Tech Inventory</h1>

  <div class="mt-2">
    <button class="border border-pink-400 rounded-4xl p-1 hover:bg-pink-600 hover:text-white cursor-pointer">Add Category</button>
    <% categories.forEach(category=>{ %>
    <a class="  
    border border-pink-400 rounded-4xl px-1 py-1.5
  hover:bg-pink-600 hover:text-white " href=<%=`/category/${category.id}`%>><%= category.name%></a>
    <% }) %>
  </div>

</body>

</html>