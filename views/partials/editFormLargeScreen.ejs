 <dialog id="add-category" class="m-auto rounded-2xl shadow-2xl border-none p-0 w-full max-w-md backdrop:bg-black/40 " >
      <div class="bg-white rounded-2xl ">

        <!--Header -->
        <div class="bg-primary-dark px-6 py-4 flex items-center justify-between">
          <h2 class="text-white font-semibold text-lg tracking-wide">Add Category</h2>
          <button onclick="removeAddCategoryForm()" class="text-white hover:text-primary-light text-xl font-bold cursor-pointer">✕</button>
        </div>

        <!-- Form -->
        <form action="addCategory" method="POST" class="px-6 py-6 flex flex-col gap-4">

          <div class="flex flex-col gap-1">
            <label for="categoryName" class="text-sm font-medium text-gray-600">Name</label>
            <input type="text" name="categoryName" id="categoryName" placeholder="e.g. Electronics" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-dark focus:border-transparent transition" />
          </div>

          <!-- Buttons -->
          <div class="flex justify-end gap-2 pt-2">
            <button type="button" onclick="removeAddCategoryForm()" class="px-4 py-2 text-sm rounded-lg border border-primary-light text-primary-dark hover:bg-red-500 hover:text-white hover:border-transparent transition cursor-pointer">
              Cancel
            </button>
            <button type="submit" class="px-4 py-2 text-sm rounded-md bg-primary-dark text-white hover:bg-primary hover:text-black transition cursor-pointer">
              Add Category
            </button>
          </div>
        </form>
      </div>
    </dialog>